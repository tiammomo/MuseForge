# MuseForge API safety switch: live generation is disabled unless explicitly enabled.
MUSEFORGE_ENABLE_LIVE_GENERATION=false

# Existing generate-product-images skill / Image2 adapter.
IMAGE_API_BASE_URL=
IMAGE_API_ENDPOINT=/images/edits
IMAGE_API_KEY=
IMAGE_MODEL=gpt-image-2
IMAGE_SIZE=1024x1024
IMAGE_QUALITY=medium
IMAGE_OUTPUT_FORMAT=png
IMAGE_COMBO_CONCURRENCY=4

# Existing CanvasPilot / ComfyUI service.
COMFYUI_BASE_URL=http://127.0.0.1:38188
